{
  "manifest_version": 3,
  "name": "JingZen Translate",
  "version": "1.0.0",
  "description": "AI-powered webpage translation using OpenAI-compatible APIs. Selection + full-page bilingual translation.",
  "author": "JingZen",
  "homepage_url": "https://github.com/jingzen/jingzen-translate",
  "minimum_chrome_version": "100",
  "permissions": ["storage", "activeTab", "contextMenus", "scripting"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "dist/popup/popup.html",
    "default_title": "JingZen Translate"
  },
  "options_page": "dist/options/options.html",
  "background": {
    "service_worker": "dist/background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["dist/content/content.js"],
      "css": ["dist/content/content.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "dist/icons/16.png",
    "48": "dist/icons/48.png",
    "128": "dist/icons/128.png"
  },
  "commands": {
    "translate-page": {
      "suggested_key": { "default": "Ctrl+Shift+Y", "mac": "Command+Shift+Y" },
      "description": "Translate current page"
    },
    "_execute_action": {
      "suggested_key": { "default": "Ctrl+Shift+J", "mac": "Command+Shift+J" }
    }
  }
}
